{
  "name": "iswitch",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:dev": "vue-tsc --noEmit && vite build --minify false --mode development",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,js,jsx,css,scss,json}\" \"src-tauri/**/*.{json,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,tsx,js,jsx,css,scss,json}\" \"src-tauri/**/*.{json,md}\" \"*.{json,md}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@lobehub/icons-static-svg": "^1.73.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-dialog": "2.4.2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "chart.js": "^4.5.1",
    "vue": "^3.5.23",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "4.0.16",
    "@vue/test-utils": "2.4.6",
    "happy-dom": "20.0.11",
    "husky": "9.1.7",
    "jsdom": "27.4.0",
    "lint-staged": "15.5.2",
    "postcss": "^8.5.6",
    "prettier": "3.7.4",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.1",
    "vitest": "4.0.16",
    "vue-tsc": "^3.1.3"
  },
  "lint-staged": {
    "**/*.{vue,ts,tsx,js,jsx,css,scss,json}": "prettier --write",
    "**/*.md": "prettier --write",
    "src-tauri/**/*.rs": "rustfmt --edition 2021"
  }
}
